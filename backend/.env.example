DATABASE_URL=postgresql+asyncpg://ecommerce:ecommerce@localhost:5432/ecommerce

JWT_SECRET=dev-secret-change-me-please-32-bytes-min
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

CORS_ORIGINS=["http://localhost:5173"]

# Frontend route used to build links inside transactional emails
# (invitations, password resets) -- not the API URL.
FRONTEND_URL=http://localhost:5173

INVITATION_TOKEN_EXPIRE_HOURS=48
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60
PASSWORD_RESET_RATE_LIMIT_PER_HOUR=3

# Defaults point at the local Mailpit container (docker-compose.yml) --
# real inbox at http://localhost:8025. Point at a real provider in
# production (SMTP_USERNAME/SMTP_PASSWORD/SMTP_USE_TLS as needed).
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USE_TLS=false
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@shopora.local
SMTP_FROM_NAME=Shopora

# INR & GST -- off by default; only ever applies to orders priced in INR.
# See README.md "INR & GST configuration" for the tax logic and a worked
# example.
GST_ENABLED=false
DEFAULT_GST_RATE_PERCENT=18.0
SELLER_STATE=Maharashtra
SELLER_GSTIN=
TAX_INCLUSIVE_PRICING=false
